{
  "name": "persol_career_tech_studio_lp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "rm": "rm -rf docs",
    "mv": "mv dist docs",
    "create:cname": "echo persol-career-techstudio.com.vn > docs/CNAME",
    "dev": "nuxt",
    "build": "nuxt build",
    "start": "nuxt start",
    "generate": "yarn rm && nuxt generate && yarn mv && yarn create:cname",
    "lint:js": "eslint --ext \".js,.vue\" .",
    "lint:js:fix": "eslint --ext \".js,.vue\" --fix .",
    "lint:css": "prettier --check \"**/*.{css,scss,html,vue}\"",
    "lint:css:fix": "prettier --write \"**/*.{css,scss,html,vue}\"",
    "format:templates": "prettier --write \"**/*.vue\"",
    "lint": "yarn lint:js && yarn lint:css",
    "lint:fix": "yarn lint:js:fix && yarn lint:css:fix",
    "prepare": "husky install"
  },
  "dependencies": {
    "@nuxtjs/google-fonts": "^3.2.0",
    "core-js": "^3.19.3",
    "eslint-plugin-no-null": "^1.0.2",
    "nuxt": "^2.15.8",
    "ress": "^5.0.2",
    "sass": "^1.77.1",
    "sass-loader": "10",
    "swiper": "5.4.5",
    "vue": "^2.6.14",
    "vue-awesome-swiper": "4.1.1",
    "vue-server-renderer": "^2.6.14",
    "vue-template-compiler": "^2.6.14",
    "vue2-smooth-scroll": "^1.6.0",
    "webpack": "^4.46.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.18.9",
    "@nuxt/types": "^2.15.8",
    "@nuxt/typescript-build": "^2.1.0",
    "@nuxtjs/eslint-config": "^10.0.0",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@nuxtjs/style-resources": "^1.2.1",
    "@typescript-eslint/parser": "^8.46.2",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.21.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.1",
    "postcss": "^8.4.0",
    "prettier": "^2.7.1",
    "pug": "^3.0.2",
    "pug-loader": "^2.4.0",
    "pug-plain-loader": "^1.1.0",
    "tailwindcss": "^3.3.0",
    "ts-loader": "8.0.0",
    "typescript": "^4.8.4"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
